# Bearer token expected in Authorization header
AUTH_TOKEN=
  # generate random string: openssl rand -hex 32

# S3 bucket name (no s3:// prefix)
BUCKET=

# Prefix for object key {SOLUTION}_clone.fmp12
SOLUTION=

# Target FileMaker Server container name or ID
FMS_CONTAINER=fms

# AWS credentials alternative — Set the three vars below and disable the mount of ~/.aws in compose.yml:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=
